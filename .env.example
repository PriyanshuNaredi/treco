# Database — use sqlite for local dev, postgres for team
DATABASE_URL=sqlite+aiosqlite:///./treco.db
DATABASE_MODE=sqlite

# For postgres:
# DATABASE_URL=postgresql+asyncpg://treco:treco@localhost:5432/treco
# DATABASE_MODE=postgres

# Auth
JWT_SECRET=change-me-in-production

# LLM (for acceptance criteria extraction)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000"]
